// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Connection {
  id               String   @id @default(uuid())
  name             String
  type             String // 'postgres' or 'mysql'
  host             String?
  port             Int?
  username         String?
  password         String?
  database         String?
  showAllDatabases Boolean  @default(false)
  createdAt        DateTime @default(now())

  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String?  // Optional for social logins
  
  // Auth Providers
  provider    String   @default("local") // "local", "google", "github"
  providerId  String?  // ID from OAuth provider
  
  // Basic Profile
  firstName   String?
  lastName    String?
  avatarUrl   String?
  bio         String?
  
  // Application Data
  role        String   @default("user")
  
  // Preferences
  theme       String   @default("dark") // "light", "dark", "system"
  language    String   @default("vi")   // "vi", "en"
  
  // Notifications
  emailNotifications Boolean @default(true)
  failedQueryAlerts  Boolean @default(true)
  productUpdates     Boolean @default(false)
  securityAlerts      Boolean @default(true)

  // Billing (Mock)
  plan               String   @default("free") // "free", "pro"
  billingDate        DateTime?
  paymentMethod      String?  // e.g., "Visa ending in 4242"

  // Onboarding Data (Progressive Profiling)
  isOnboarded Boolean  @default(false)
  username    String?  @unique
  jobRole     String?  // e.g., "Data Engineer", "Analyst"
  phoneNumber String?
  address     String?
  
  // Password Reset
  resetOtp       String?
  resetOtpExpiry DateTime?
  lastLoginIp    String?

  // Email Verification
  isEmailVerified Boolean @default(false)
  verifyOtp       String?
  verifyOtpExpiry DateTime?

  // Admin Management
  isBanned        Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  auditLogs   AuditLog[]
  connections Connection[]
  aiChats     AiChat[]
}

model AiChat {
  id               String      @id @default(uuid())
  title            String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  connectionId     String?
  database         String?
  
  messages         AiMessage[]
}

model AiMessage {
  id               String   @id @default(uuid())
  chatId           String
  chat             AiChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  
  role             String   // "user" or "ai"
  content          String
  sql              String?
  explanation      String?
  error            Boolean  @default(false)
  attachments      Json?
  
  createdAt        DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String?
  details   String? // JSON stringified details
  ipAddress String?
  createdAt DateTime @default(now())

  // Optional relation if we want to tie logs strictly to users, 
  // though nullable since some actions (like failed logins) might not have a hard user ID link
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
