// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ResourceType {
  CONNECTION
  QUERY
  DASHBOARD
  ERD
}

// ─── Core Models ───

model Connection {
  id               String   @id @default(uuid())
  name             String
  type             String // 'postgres', 'mysql', 'mssql', 'mongodb', 'mongodb+srv'
  host             String?
  port             Int?
  username         String?
  password         String?
  database         String?
  showAllDatabases Boolean  @default(false)
  readOnly         Boolean  @default(false)
  allowSchemaChanges Boolean @default(true)
  allowImportExport Boolean @default(true)
  allowQueryExecution Boolean @default(true)
  lastHealthCheckAt DateTime?
  lastHealthStatus  String?
  lastHealthError   String?
  lastConnectedAt   DateTime?
  lastConnectionLatencyMs Int?
  createdAt        DateTime @default(now())

  sshHost          String?
  sshPort          Int     @default(22)
  sshUsername      String?
  sshPrivateKey    String?
  sshPassphrase    String?

  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([name, userId])
  @@index([organizationId])
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String?  // Optional for social logins

  // Auth Providers
  provider    String   @default("local") // "local", "google", "github"
  providerId  String?  // ID from OAuth provider

  // Basic Profile
  firstName   String?
  lastName    String?
  avatarUrl   String?
  bio         String?

  // Application Data
  role        String   @default("user")

  // Preferences
  theme       String   @default("dark") // "light", "dark", "system"
  language    String   @default("vi")   // "vi", "en"

  // Notifications
  emailNotifications Boolean @default(true)
  failedQueryAlerts  Boolean @default(true)
  productUpdates     Boolean @default(false)
  securityAlerts      Boolean @default(true)

  // Billing (Mock)
  plan               String   @default("free") // "free", "pro"
  billingDate        DateTime?
  paymentMethod      String?  // e.g., "Visa ending in 4242"

  // Onboarding Data (Progressive Profiling)
  isOnboarded Boolean  @default(false)
  username    String?  @unique
  jobRole     String?  // e.g., "Data Engineer", "Analyst"
  phoneNumber String?
  address     String?

  // Password Reset
  resetOtp       String?
  resetOtpExpiry DateTime?
  lastLoginIp    String?
  refreshTokenHash   String?
  refreshTokenExpiry DateTime?

  // Email Verification
  isEmailVerified Boolean @default(false)
  verifyOtp       String?
  verifyOtpExpiry DateTime?

  // Admin Management
  isBanned        Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auditLogs   AuditLog[]
  connections Connection[]
  aiChats     AiChat[]
  savedQueries SavedQuery[]
  dashboards  Dashboard[]
  erdWorkspaces ErdWorkspace[]
  organizationMembers OrganizationMember[]
}

model AiChat {
  id               String      @id @default(uuid())
  title            String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  connectionId     String?
  database         String?

  messages         AiMessage[]
}

model AiMessage {
  id               String   @id @default(uuid())
  chatId           String
  chat             AiChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  role             String   // "user" or "ai"
  content          String
  sql              String?
  explanation      String?
  error            Boolean  @default(false)
  attachments      Json?

  createdAt        DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String?
  details   String? // JSON stringified details
  ipAddress String?
  createdAt DateTime @default(now())
  
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SavedQuery {
  id          String   @id @default(uuid())
  name        String
  sql         String
  database    String?
  connectionId String?
  visibility  String   @default("private")
  folderId    String?
  tags        String[] @default([])
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([visibility, updatedAt])
  @@index([organizationId])
}

model Dashboard {
  id           String   @id @default(uuid())
  name         String
  description  String?
  visibility   String   @default("private")
  connectionId String?
  database     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets      DashboardWidget[]

  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([visibility, updatedAt])
  @@index([organizationId])
}

model DashboardWidget {
  id           String   @id @default(uuid())
  title        String
  chartType    String
  queryText    String?
  connectionId String?
  database     String?
  columns      String[] @default([])
  xAxis        String?
  yAxis        String[] @default([])
  orderIndex   Int      @default(0)
  config       Json?
  dataSnapshot Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dashboardId  String
  dashboard    Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId, orderIndex])
}

model ErdWorkspace {
  id           String   @id @default(uuid())
  name         String
  notes        String?
  connectionId String?
  database     String?
  layout       Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([connectionId, updatedAt])
  @@index([organizationId])
}

// ─── Organization / Team Collaboration ───

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  settings  Json?    @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   OrganizationMember[]
  invitations OrganizationInvitation[]
  resources OrganizationResource[]
  auditLogs AuditLog[]
  connections Connection[]
  savedQueries SavedQuery[]
  dashboards Dashboard[]
  erdWorkspaces ErdWorkspace[]
}

model OrganizationMember {
  id             String           @id @default(uuid())
  role           OrganizationRole @default(MEMBER)
  invitedBy      String?
  invitedAt      DateTime         @default(now())
  joinedAt       DateTime?

  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationInvitation {
  id               String           @id @default(uuid())
  email            String
  role             OrganizationRole @default(MEMBER)
  invitedBy        String?
  invitedAt        DateTime         @default(now())
  acceptedAt       DateTime?
  acceptedByUserId String?

  organizationId   String
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
  @@index([acceptedAt])
}

model OrganizationResource {
  id             String       @id @default(uuid())
  resourceType   ResourceType
  resourceId     String
  permissions    Json         @default("{}")
  createdAt      DateTime     @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([resourceType, resourceId, organizationId])
  @@index([organizationId])
  @@index([resourceType, resourceId])
}
