# Render Backend Environment Variables
# Set these in Render Dashboard > Environment

# Port (Render sets this automatically, do NOT set manually)
# PORT=

# Database URL for Prisma (if using Prisma for auth/sessions)
DATABASE_URL=file:./dev.db

# JWT Secret — use a strong random string in production
JWT_SECRET=change-me-to-a-strong-random-string

# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-frontend.vercel.app
