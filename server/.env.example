# Backend Settings
PORT=3001

# App database connection
# Local non-Docker example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/data_explorer
# Docker Compose example:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/data_explorer

# Security
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes-long
ENCRYPTION_KEY=replace-with-exactly-32-random-characters
LEGACY_ENCRYPTION_KEYS=
ALLOW_INTERNAL_IPS=false

# AI
GEMINI_API_KEY=your-gemini-key
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_CHAT_MODEL=llama3.1-8b
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=

# Frontend URL for CORS and OAuth redirects
# Vite local dev:
FRONTEND_URL=http://localhost:5173
# Docker-served frontend example:
# FRONTEND_URL=http://localhost

# Auth Providers
GOOGLE_CLIENT_ID=your-google-id
GOOGLE_CLIENT_SECRET=your-google-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

GITHUB_CLIENT_ID=your-github-id
GITHUB_CLIENT_SECRET=your-github-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Email Settings
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
